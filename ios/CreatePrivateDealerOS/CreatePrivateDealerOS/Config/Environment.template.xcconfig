// Copy values into Debug.xcconfig and Release.xcconfig
SUPABASE_URL = https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY = REPLACE_WITH_SUPABASE_ANON_KEY
BACKEND_BASE_URL = https://YOUR_BACKEND_DOMAIN
ENABLE_MOCK_MODE = 0
ALLOW_ADMIN_PHONE_UNMASK = 1
MARKETING_CAN_VIEW_MESSAGES_DEFAULT = 0
MISSED_LEAD_MINUTES = 10
